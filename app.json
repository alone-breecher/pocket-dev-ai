{
  "expo": {
    "name": "PocketDevAI",
    "slug": "pocket-dev-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pocketdevai.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.pocketdevai.app",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET"
      ],
      "versionCode": 1,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "minSdkVersion": 23
    },
    "plugins": [
      "expo-secure-store",
      "expo-document-picker",
      [
        "expo-file-system",
        {
          "photosPermission": "Allow PocketDevAI to access photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "pocket-dev-ai"
      }
    }
  }
}
